// Schema — SaaS Multi-tenant para Gestão de Lojas Maçônicas
// Toda entidade de negócio carrega lodgeId (tenant) e todas as
// queries da aplicação DEVEM filtrar por ele.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Tenant ───────────────────────────

model Lodge {
  id                 String   @id @default(cuid())
  name               String
  number             String   @unique // nº da Loja na potência
  potencia           String? // GOB, GLESP, COMAB etc.
  oriente            String? // cidade/UF
  address            String? // endereço da sede (citado no texto das atas)
  driveFolderId      String? // pasta raiz da Loja no Google Drive
  pixKey             String? // chave Pix da Loja (recebimento das capitações)
  logoUrl            String? // logo da Loja (data URI ou URL)
  // Frequência mínima (%) nas sessões durante o processo de progressão
  // (trava da coluna Instrução e Frequência — ajuste conforme o regulamento)
  minFreqProgressao  Int      @default(50)
  // Nº de capitações vencidas para o membro ficar IRREGULAR (inadimplência)
  limiteInadimplencia Int     @default(3)
  // Gateway de pagamento Asaas (cobrança recorrente cartão/boleto)
  asaasApiKey        String? // API key da conta Asaas da Loja
  asaasWebhookToken  String? // token conferido no header asaas-access-token do webhook
  googleRefreshToken String? // OAuth do Google da Loja (conexão ao Drive)
  googleEmail        String? // conta Google conectada
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  users             User[]
  degreeHistory     DegreeHistory[]
  roleHistory       RoleHistory[]
  sessions          LodgeSession[]
  attendances       Attendance[]
  atas              Ata[]
  pranchas          Prancha[]
  documents         Document[]
  invoices          Invoice[]
  expenses          Expense[]
  transactions      Transaction[]
  donations         Donation[]
  events            CharityEvent[]
  processosAdmissao   ProcessoAdmissao[]
  processosProgressao ProcessoProgressao[]
  quittePlacets       QuittePlacet[]
  notifications       Notification[]

  @@map("lodges")
}

// ─────────────────────────── Usuários ───────────────────────────

enum Degree {
  APRENDIZ
  COMPANHEIRO
  MESTRE
}

enum Role {
  MEMBER // Obreiro comum
  VENERAVEL_MESTRE
  SECRETARIO
  TESOUREIRO
  CONSELHO_CONTAS // somente leitura em Secretaria/Tesouraria
  SUPER_ADMIN // admin master do SaaS — cria e administra lojas (tenants)
}

enum MemberStatus {
  ATIVO
  IRREGULAR // inadimplente
  LICENCIADO
  EX_MEMBRO
}

model User {
  id             String       @id @default(cuid())
  lodgeId        String
  cim            String       @unique // Cadastro de Identificação Maçônica
  cpf            String       @unique
  name           String
  email          String       @unique
  phone          String?
  address        String?
  birthDate      DateTime?
  profession     String?
  passwordHash   String
  // Força troca de senha no primeiro acesso (senha provisória = CPF)
  mustChangePassword Boolean  @default(false)
  // Recuperação de senha: código 2FA enviado por e-mail (hash bcrypt)
  resetCodeHash      String?
  resetCodeExpiresAt DateTime?
  resetCodeAttempts  Int       @default(0)
  // Gateway Asaas: cliente e assinatura recorrente da capitação
  asaasCustomerId     String?
  asaasSubscriptionId String?
  degree         Degree       @default(APRENDIZ)
  currentRole    Role         @default(MEMBER)
  status         MemberStatus @default(ATIVO)
  initiationDate DateTime? // data de iniciação (base do interstício)

  // Painel de Privacidade (LGPD): visibilidade de contatos aos demais membros
  isDataPublic  Boolean @default(false)
  showEmail     Boolean @default(false)
  showPhone     Boolean @default(false)
  showAddress   Boolean @default(false)
  showBirthDate Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge                 Lodge           @relation(fields: [lodgeId], references: [id])
  degreeHistory         DegreeHistory[]
  roleHistory           RoleHistory[]
  attendances           Attendance[]
  invoices              Invoice[]
  donations             Donation[]
  atasAsMaster          Ata[]           @relation("AtaMaster")
  atasAsSec             Ata[]           @relation("AtaSecretary")
  expensesAsMaster      Expense[]       @relation("ExpenseMaster")
  expensesAsTreasurer   Expense[]       @relation("ExpenseTreasurer")
  documentsUploaded     Document[]
  quittePlacets         QuittePlacet[]
  quittePlacetsAsMaster QuittePlacet[]  @relation("QuittePlacetMaster")
  quittePlacetsAsSec    QuittePlacet[]  @relation("QuittePlacetSecretary")
  notifications         Notification[]
  processosProgressao   ProcessoProgressao[]

  @@index([lodgeId])
  @@map("users")
}

// Evolução de graus com controle de interstício
model DegreeHistory {
  id        String   @id @default(cuid())
  lodgeId   String
  userId    String
  degree    Degree
  date      DateTime // data da elevação/exaltação/iniciação
  ataId     String? // ata da sessão em que ocorreu
  createdAt DateTime @default(now())

  lodge Lodge @relation(fields: [lodgeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([lodgeId])
  @@index([userId])
  @@map("degree_history")
}

// Histórico cronológico de cargos
model RoleHistory {
  id        String    @id @default(cuid())
  lodgeId   String
  userId    String
  role      Role
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())

  lodge Lodge @relation(fields: [lodgeId], references: [id])
  user  User  @relation(fields: [userId], references: [id])

  @@index([lodgeId])
  @@index([userId])
  @@map("role_history")
}

// ─────────────── Sessões, Presenças e Atas ───────────────

enum SessionType {
  ORDINARIA
  MAGNA
  ECONOMICA
  BRANCA
}

model LodgeSession {
  id        String      @id @default(cuid())
  lodgeId   String
  date      DateTime
  type      SessionType @default(ORDINARIA)
  degree    Degree      @default(APRENDIZ) // grau em que a sessão foi aberta
  qrToken   String      @unique @default(cuid()) // check-in via QR Code
  createdAt DateTime    @default(now())

  lodge       Lodge        @relation(fields: [lodgeId], references: [id])
  attendances Attendance[]
  ata         Ata?

  @@index([lodgeId])
  @@map("lodge_sessions")
}

// Livro de Presenças (membros e visitantes)
model Attendance {
  id              String   @id @default(cuid())
  lodgeId         String
  sessionId       String
  userId          String? // null = visitante
  // dados do visitante
  visitorName     String?
  visitorCim      String?
  visitorLodge    String? // loja de origem
  visitorPotencia String? // potência de origem
  checkedInAt     DateTime @default(now())
  viaQrCode       Boolean  @default(false)

  lodge   Lodge        @relation(fields: [lodgeId], references: [id])
  session LodgeSession @relation(fields: [sessionId], references: [id])
  user    User?        @relation(fields: [userId], references: [id])

  @@unique([sessionId, userId])
  @@index([lodgeId])
  @@map("attendances")
}

enum AtaStatus {
  RASCUNHO
  AGUARDANDO_ASSINATURAS
  ASSINADA // VM + Secretário assinaram — imutável
}

// Ata (Balaústre) — trava: exige assinatura conjunta de VM e Secretário
model Ata {
  id        String    @id @default(cuid())
  lodgeId   String
  sessionId String    @unique
  number    Int // numeração sequencial por loja
  content   String
  status    AtaStatus @default(RASCUNHO)

  signedByMasterId String?
  signedByMasterAt DateTime?
  signedBySecId    String?
  signedBySecAt    DateTime?

  driveFileId String? // PDF assinado no Google Drive
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lodge          Lodge        @relation(fields: [lodgeId], references: [id])
  session        LodgeSession @relation(fields: [sessionId], references: [id])
  signedByMaster User?        @relation("AtaMaster", fields: [signedByMasterId], references: [id])
  signedBySec    User?        @relation("AtaSecretary", fields: [signedBySecId], references: [id])

  @@unique([lodgeId, number])
  @@map("atas")
}

// ─────────────── Documentos e Pranchas ───────────────

// Correspondência expedida com numeração sequencial automática
model Prancha {
  id          String   @id @default(cuid())
  lodgeId     String
  number      Int // sequencial por loja/ano
  year        Int
  subject     String
  recipient   String
  content     String
  driveFileId String?
  createdAt   DateTime @default(now())

  lodge Lodge @relation(fields: [lodgeId], references: [id])

  @@unique([lodgeId, year, number])
  @@map("pranchas")
}

enum DocumentType {
  ATA_ESCANEADA
  HISTORICO
  REGULAMENTO
  FINANCEIRO
  OUTRO
}

model Document {
  id           String       @id @default(cuid())
  lodgeId      String
  uploadedById String
  title        String
  type         DocumentType @default(OUTRO)
  driveFileId  String // arquivo no Google Drive da Loja
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime     @default(now())

  lodge      Lodge @relation(fields: [lodgeId], references: [id])
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@index([lodgeId])
  @@map("documents")
}

// ─────────────── Tesouraria ───────────────

enum InvoiceStatus {
  PENDENTE
  PAGA
  VENCIDA
  CANCELADA
}

enum PaymentMethod {
  PIX
  CARTAO
  BOLETO
  DINHEIRO
  MANUAL
}

// Mensalidade (capitação) gerada automaticamente para membros ativos
model Invoice {
  id             String        @id @default(cuid())
  lodgeId        String
  userId         String
  description    String // ex.: "Capitação 07/2026"
  referenceMonth Int
  referenceYear  Int
  amountCents    Int
  dueDate        DateTime
  status         InvoiceStatus @default(PENDENTE)

  // Pix dinâmico
  pixTxid         String?        @unique // id da cobrança no PSP (chave do webhook)
  pixCopiaECola   String?
  paidAt          DateTime?
  paidMethod      PaymentMethod?
  gatewayChargeId   String? @unique // id do pagamento no gateway (chave do webhook Asaas)
  gatewayInvoiceUrl String? // link de pagamento (boleto/cartão/Pix) no gateway

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge       Lodge        @relation(fields: [lodgeId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  transaction Transaction?

  @@unique([lodgeId, userId, referenceYear, referenceMonth])
  @@index([lodgeId])
  @@map("invoices")
}

enum ExpenseStatus {
  PENDENTE_APROVACAO
  APROVADA // VM + Tesoureiro aprovaram
  PAGA
  REJEITADA
}

// Despesa — trava: exige aprovação dupla de VM e Tesoureiro
model Expense {
  id          String        @id @default(cuid())
  lodgeId     String
  description String
  supplier    String?
  amountCents Int
  dueDate     DateTime?
  status      ExpenseStatus @default(PENDENTE_APROVACAO)

  approvedByMasterId    String?
  approvedByMasterAt    DateTime?
  approvedByTreasurerId String?
  approvedByTreasurerAt DateTime?
  paidAt                DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lodge               Lodge        @relation(fields: [lodgeId], references: [id])
  approvedByMaster    User?        @relation("ExpenseMaster", fields: [approvedByMasterId], references: [id])
  approvedByTreasurer User?        @relation("ExpenseTreasurer", fields: [approvedByTreasurerId], references: [id])
  transaction         Transaction?

  @@index([lodgeId])
  @@map("expenses")
}

enum TransactionType {
  RECEITA
  DESPESA
}

// Livro-caixa consolidado — base dos balancetes mensais
model Transaction {
  id          String          @id @default(cuid())
  lodgeId     String
  type        TransactionType
  description String
  amountCents Int
  date        DateTime
  category    String? // capitação, tronco, evento, aluguel...
  invoiceId   String?         @unique
  expenseId   String?         @unique
  donationId  String?         @unique
  createdAt   DateTime        @default(now())

  lodge    Lodge     @relation(fields: [lodgeId], references: [id])
  invoice  Invoice?  @relation(fields: [invoiceId], references: [id])
  expense  Expense?  @relation(fields: [expenseId], references: [id])
  donation Donation? @relation(fields: [donationId], references: [id])

  @@index([lodgeId, date])
  @@map("transactions")
}

enum DonationType {
  TRONCO_SOLIDARIEDADE
  INGRESSO_EVENTO
  DOACAO_AVULSA
}

// Arrecadações extras: tronco e eventos beneficentes
model Donation {
  id          String       @id @default(cuid())
  lodgeId     String
  userId      String? // anônimo se null
  eventId     String?
  type        DonationType
  amountCents Int
  date        DateTime     @default(now())

  lodge       Lodge         @relation(fields: [lodgeId], references: [id])
  user        User?         @relation(fields: [userId], references: [id])
  event       CharityEvent? @relation(fields: [eventId], references: [id])
  transaction Transaction?

  @@index([lodgeId])
  @@map("donations")
}

model CharityEvent {
  id               String   @id @default(cuid())
  lodgeId          String
  name             String
  date             DateTime
  ticketPriceCents Int?
  createdAt        DateTime @default(now())

  lodge     Lodge      @relation(fields: [lodgeId], references: [id])
  donations Donation[]

  @@index([lodgeId])
  @@map("charity_events")
}

// ─────────────── Módulo Secretaria: Kanban (loja.md §4) ───────────────

enum StatusAdmissao {
  DOCUMENTACAO
  EDITAL_PUBLICADO
  SINDICANCIA
  ESCRUTINIO
  AGUARDANDO_PLACET
  INICIADO
  REPROVADO
}

// Pipeline de Admissão (Iniciação) — candidato profano até virar obreiro
model ProcessoAdmissao {
  id               String         @id @default(cuid())
  lodgeId          String
  nomeCandidato    String
  cpf              String?
  email            String?
  phone            String?
  status           StatusAdmissao @default(DOCUMENTACAO)
  certidoesValidas Boolean        @default(false)
  dataEscrutinio   DateTime?
  aprovado         Boolean?
  observacoes      String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  lodge Lodge @relation(fields: [lodgeId], references: [id])

  @@index([lodgeId])
  @@map("processos_admissao")
}

enum StatusPlacet {
  PENDENTE
  EM_ANALISE
  APROVADO
  NEGADO
}

// Quitte Placet (desligamento/filiação) — trava: exige Nada Consta da Tesouraria
// e dupla assinatura (VM + Secretário) para emissão final
model QuittePlacet {
  id                 String       @id @default(cuid())
  userId             String
  lodgeId            String
  motivo             String?
  dataSolicitacao    DateTime     @default(now())
  quitacaoFinanceira Boolean      @default(false)
  status             StatusPlacet @default(PENDENTE)

  signedByMasterId String?
  signedByMasterAt DateTime?
  signedBySecId    String?
  signedBySecAt    DateTime?

  driveFileId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User  @relation(fields: [userId], references: [id])
  lodge          Lodge @relation(fields: [lodgeId], references: [id])
  signedByMaster User? @relation("QuittePlacetMaster", fields: [signedByMasterId], references: [id])
  signedBySec    User? @relation("QuittePlacetSecretary", fields: [signedBySecId], references: [id])

  @@index([lodgeId])
  @@map("quitte_placets")
}

enum StatusProgressao {
  CUMPRIMENTO_INTERSTICIO
  INSTRUCAO_E_FREQUENCIA
  EXAME_PROFICIENCIA
  ESCRUTINIO_PROGRESSAO
  AGUARDANDO_PLACET
  AGUARDANDO_CERIMONIA
  COMUNICACAO_POS_CERIMONIA
  GRAU_CONCEDIDO
}

// Pipeline de Progressão de Graus (loja.md §4.B) — travas da Guarda dos
// Selos (placetDeferido) e da comunicação de 15 dias (comunicadoEnviado)
model ProcessoProgressao {
  id                String           @id @default(cuid())
  userId            String
  lodgeId           String
  grauAlvo          Degree // COMPANHEIRO ou MESTRE
  status            StatusProgressao @default(CUMPRIMENTO_INTERSTICIO)

  dataInicio        DateTime         @default(now())
  dataAprovacao     DateTime? // data que passou no escrutínio
  placetDeferido    Boolean          @default(false) // trava da Guarda dos Selos
  dataCerimonia     DateTime? // data da Elevação ou Exaltação
  comunicadoEnviado Boolean          @default(false) // trava dos 15 dias (Sua Sessão no GOB-SP)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id])
  lodge Lodge @relation(fields: [lodgeId], references: [id])

  @@index([lodgeId])
  @@map("processos_progressao")
}

enum NotificationType {
  PENDING_SIGNATURE
  DEADLINE_WARNING
  MISSING_DATA
  FINANCIAL_APPROVAL
}

// Central de alertas (to-do de assinaturas, prazos de 15 dias, cadastro incompleto)
model Notification {
  id          String           @id @default(cuid())
  lodgeId     String
  userId      String?
  title       String
  description String
  type        NotificationType
  isRead      Boolean          @default(false)
  dueDate     DateTime?
  createdAt   DateTime         @default(now())
  // Chave determinística da origem (ex.: "ata:<id>") — garante geração idempotente
  sourceKey   String?
  // Rota interna do recurso relacionado (ex.: "/secretaria/atas/<id>")
  link        String?

  lodge Lodge @relation(fields: [lodgeId], references: [id])
  user  User? @relation(fields: [userId], references: [id])

  @@unique([lodgeId, sourceKey])
  @@index([lodgeId])
  @@map("notifications")
}
